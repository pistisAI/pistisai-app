# Pistisai Production Environment Variables
# Copy this file to .env and fill in the values

# ================================
# Auth0 Authentication
# ================================
AUTH0_DOMAIN=your-domain.auth0.com
AUTH0_AUDIENCE=https://api.pistisai.app

# ================================
# Security
# ================================
JWT_SECRET=your-super-secret-jwt-key-change-this
REDIS_PASSWORD=your-redis-password-change-this

# ================================
# SSL/TLS (Let's Encrypt)
# ================================
LETSENCRYPT_EMAIL=admin@pistisai.app

# ================================
# Monitoring & Error Tracking
# ================================
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
GRAFANA_ADMIN_PASSWORD=change-this-grafana-password

# ================================
# OpenTelemetry Tracing
# ================================
OTLP_ENDPOINT=http://jaeger:4318

# ================================
# Domain Configuration
# ================================
# If you have a custom domain, update these
API_DOMAIN=api.pistisai.app
STREAMING_DOMAIN=stream.pistisai.app
GRAFANA_DOMAIN=grafana.pistisai.app
PROMETHEUS_DOMAIN=prometheus.pistisai.app
