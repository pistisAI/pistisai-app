[Unit]
Description=Zoidbot System Tray Daemon
Documentation=https://zoidbot.online
After=graphical-session.target
Wants=graphical-session.target

[Service]
Type=simple
User=%i
Group=%i
ExecStart=/usr/bin/zoidbot-tray
ExecReload=/bin/kill -HUP $MAINPID
Restart=on-failure
RestartSec=5
TimeoutStopSec=30

# Security settings
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=false
ReadWritePaths=/home/%i/.zoidbot

# Environment
Environment=HOME=/home/%i
Environment=XDG_CONFIG_HOME=/home/%i/.config
Environment=DISPLAY=:0

# Logging
StandardOutput=journal
StandardError=journal
SyslogIdentifier=zoidbot-tray

[Install]
WantedBy=default.target
