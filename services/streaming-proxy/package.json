{
  "name": "Pistisai-tunnel-container",
  "version": "10.1.187",
  "description": "Simplified tunnel-aware container for Pistisai using standard HTTP libraries",
  "main": "proxy-server.js",
  "type": "module",
  "scripts": {
    "start": "node proxy-server.js",
    "health": "node health-check.js",
    "test-tunnel": "node test-tunnel.js",
    "dev": "node --inspect proxy-server.js",
    "build": "tsc",
    "test": "node --experimental-vm-modules ../../node_modules/jest/bin/jest.js",
    "lint": "eslint .",
    "format": "eslint . --fix"
  },
  "keywords": [
    "tunnel",
    "container",
    "http-client",
    "multi-tenant",
    "Pistisai"
  ],
  "author": "Pistisai",
  "license": "MIT",
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.78.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.219.0",
    "@opentelemetry/sdk-node": "^0.220.0",
    "@sentry/node": "^10.49.0",
    "@sentry/profiling-node": "^10.60.0",
    "@types/jsonwebtoken": "^9.0.10",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "jwks-rsa": "^4.1.0",
    "prom-client": "^15.1.3",
    "stripe": "^22.2.0",
    "uuid": "^14.0.1",
    "winston": "^3.19.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^22.19.17",
    "@types/ws": "^8.18.1",
    "eslint": "^9.39.4",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22.0.0 <25.0.0"
  },
  "overrides": {
    "glob": "^11.0.0",
    "@types/node": "^22.19.17",
    "@types/ws": "^8.18.1",
    "eslint": "^9.39.4",
    "husky": "^9.1.7",
    "typescript": "^5.9.3"
  }
}
