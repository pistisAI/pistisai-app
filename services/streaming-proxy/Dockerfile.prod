# ============================================================================
# Runtime Dockerfile for Pistisai Streaming Proxy
# Uses standard Node.js Alpine images
# ============================================================================

FROM node:24-alpine

WORKDIR /app

COPY package*.json ./
RUN npm ci --omit=dev

COPY . ./

RUN chown -R node:node /app

USER node

ENV NODE_ENV=production
ENV PORT=3001

EXPOSE 3001

CMD ["node", "proxy-server.js"]
