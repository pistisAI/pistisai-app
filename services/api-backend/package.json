{
  "name": "pistisai-api-backend",
  "version": "10.1.187",
  "description": "Pistisai API Backend for Bridge Communication",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --forceExit",
    "test:unit": "node --experimental-vm-modules node_modules/jest/bin/jest.js ../../test/api-backend/ --forceExit --detectOpenHandles",
    "test:integration": "node --experimental-vm-modules node_modules/jest/bin/jest.js ../../test/api-backend/ --forceExit",
    "test:security": "node --experimental-vm-modules node_modules/jest/bin/jest.js ../../test/api-backend/ --forceExit",
    "test:tunnel": "node --experimental-vm-modules node_modules/jest/bin/jest.js ../../test/api-backend/ --forceExit",
    "test:tunnel:unit": "node --experimental-vm-modules node_modules/jest/bin/jest.js ../../test/api-backend/ --forceExit",
    "test:tunnel:integration": "node --experimental-vm-modules node_modules/jest/bin/jest.js ../../test/api-backend/ --forceExit",
    "test:tunnel:security": "node --experimental-vm-modules node_modules/jest/bin/jest.js ../../test/api-backend/ --forceExit",
    "test:user-isolation": "node --experimental-vm-modules node_modules/jest/bin/jest.js ../../test/api-backend/security/user-isolation.test.js --forceExit",
    "test:auth": "node --experimental-vm-modules node_modules/jest/bin/jest.js ../../test/api-backend/security/authentication-authorization.test.js --forceExit",
    "test:security:verbose": "node --experimental-vm-modules node_modules/jest/bin/jest.js ../../test/api-backend/security/ --verbose --forceExit",
    "db:migrate": "node database/migrate-pg.js init",
    "db:validate": "node database/migrate-pg.js validate",
    "db:stats": "node database/migrate-pg.js stats",
    "db:test": "node scripts/test-database.js",
    "db:setup-cloud-sql": "bash scripts/setup-cloud-sql.sh",
    "deploy:cloud-run": "bash scripts/deploy-cloud-run.sh",
    "test:auth-flow": "node scripts/test-auth-flow.js",
    "deploy:after-auth": "bash scripts/deploy-after-auth.sh",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@kubernetes/client-node": "^1.4.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.78.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.219.0",
    "@opentelemetry/resources": "^2.8.0",
    "@opentelemetry/sdk-node": "^0.220.0",
    "@opentelemetry/sdk-trace-base": "^2.8.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@sentry/node": "^10.57.0",
    "axios": "^1.15.0",
    "cors": "^2.8.6",
    "dockerode": "^5.0.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-oauth2-jwt-bearer": "^1.8.0",
    "express-rate-limit": "^8.5.2",
    "googleapis": "^173.0.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.3",
    "jwks-rsa": "^4.1.0",
    "node-fetch": "^3.3.2",
    "nodemailer": "^9.0.1",
    "pg": "^8.20.0",
    "prom-client": "^15.1.3",
    "rate-limit-redis": "^5.0.0",
    "ssh2": "^1.17.0",
    "stripe": "^22.3.0",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^14.0.0",
    "validator": "^13.15.35",
    "winston": "^3.19.0",
    "winston-transport": "^4.9.0",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "auth0": "^6.0.0",
    "eslint": "^10.4.1",
    "fast-check": "^4.8.0",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "jest-junit": "^17.0.0",
    "nock": "^14.0.12",
    "node-fetch": "^3.3.2",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.4",
    "supertest": "^7.2.2"
  },
  "engines": {
    "node": ">=22.0.0 <25.0.0"
  },
  "overrides": {
    "glob": "^11.0.0",
    "rimraf": "^6.0.1",
    "inflight": "npm:@zkochan/inflight@^2.0.0",
    "@npmcli/move-file": "npm:@npmcli/fs@^3.1.1",
    "npmlog": "npm:proc-log@^5.0.0",
    "gauge": "npm:are-we-there-yet@^5.0.0",
    "are-we-there-yet": "^5.0.0",
    "google-p12-pem": "npm:gcp-metadata@^6.1.0",
    "test-exclude": "^7.0.1",
    "minimatch": "^10.2.1"
  },
  "keywords": [
    "Pistisai",
    "api",
    "bridge",
    "websocket",
    "ollama",
    "trigger-ci"
  ],
  "author": "Pistisai Team",
  "license": "MIT"
}
