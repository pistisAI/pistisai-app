{
  "name": "@CloudToLocalLLM/sdk",
  "version": "2.0.0",
  "description": "Official JavaScript/TypeScript SDK for CloudToLocalLLM API",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./client": {
      "import": "./dist/client.js",
      "types": "./dist/client.d.ts"
    },
    "./types": {
      "import": "./dist/types.js",
      "types": "./dist/types.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "CloudToLocalLLM",
    "sdk",
    "api",
    "typescript",
    "javascript"
  ],
  "author": "CloudToLocalLLM Team",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.15.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "eslint": "^9.39.4",
    "jest": "^29.7.0",
    "prettier": "^3.8.3",
    "ts-jest": "^29.4.9",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/CloudToLocalLLM/CloudToLocalLLM.git"
  },
  "bugs": {
    "url": "https://github.com/CloudToLocalLLM/CloudToLocalLLM/issues"
  },
  "homepage": "https://pistisai.app"
}
